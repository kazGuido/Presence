DATABASE_URL=sqlite:///./data/app.db
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
PUBLIC_APP_URL=http://127.0.0.1:5173
# Baileys bridge base URL (no path). API uses /t/{company_uuid}/send|qr|health — one WA session per company.
WHATSAPP_BRIDGE_URL=
WHATSAPP_BRIDGE_SECRET=
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5

# Redis: employee verification codes + ARQ worker broker
REDIS_URL=

# SMTP (email attendance links + verification codes)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Attendance
SMTP_USE_TLS=true

# MinIO (optional; when set, punch photos go to the bucket instead of UPLOAD_DIR)
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=attendance
MINIO_SECURE=false

# Pre-shift reminder: minutes before schedule start to send link (worker)
REMINDER_LEAD_MINUTES=30
