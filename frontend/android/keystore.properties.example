# Copy to keystore.properties (gitignored) next to this file.
# storeFile is relative to the `android/` directory (e.g. app/release.keystore if you place the file in android/app/).
# Generate a keystore:
#   keytool -genkey -v -keystore app/release.keystore -alias presence -keyalg RSA -keysize 2048 -validity 10000

storeFile=app/release.keystore
storePassword=changeit
keyAlias=presence
keyPassword=changeit
