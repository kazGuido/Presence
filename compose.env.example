# Copy to `.env` in the repo root (Compose reads it automatically).
# Do not commit `.env` if it contains secrets.

API_PORT=18080
PUBLIC_APP_URL=https://your-public-domain.example

# --- PostgreSQL (Compose production/default database) ---
POSTGRES_DB=presence
POSTGRES_USER=presence
POSTGRES_PASSWORD=change-me-postgres-password

# --- Nginx Proxy Manager (required for public HTTPS without 502) ---
# The `api` service must share a network with NPM. Defaults match common NPM installs.
# List NPM’s networks: docker inspect nginx-proxy-manager --format '{{range $k,$v := .NetworkSettings.Networks}}{{$k}} {{end}}'
# Create `proxy` if missing: docker network create proxy
NPM_PROXY_NETWORK=proxy
NPM_APP_NETWORK=nginx-proxy-manager_npm-network

JWT_SECRET=change-me-in-production
WHATSAPP_BRIDGE_SECRET=change-me-bridge-secret

# --- Platform super admin / observability ---
SUPER_ADMIN_EMAIL=ops@example.com
SUPER_ADMIN_PASSWORD=change-me-super-admin-password
SUPER_ADMIN_WEEKLY_REPORT_ENABLED=false
SUPER_ADMIN_REPORT_EMAILS=ops@example.com,founder@example.com
SUPER_ADMIN_WEEKLY_REPORT_WEEKDAY=0
SUPER_ADMIN_WEEKLY_REPORT_HOUR_UTC=8
